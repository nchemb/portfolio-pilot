generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id        String   @id // Clerk userId
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile      Profile?
  accounts     BrokerageAccount[]
  cashAccounts CashAccount[]
  plaidItems   PlaidItem[]
  overrides    UserSecurityOverride[]
}

model Profile {
  id            String   @id @default(cuid())
  userId        String   @unique
  ageRange      String?
  riskTolerance String?  // low|medium|high
  timeHorizon   String?  // short|long
  monthlyContributionCents Int? // default monthly contribution for rebalancer (in cents)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BrokerageAccount {
  id           String   @id @default(cuid())
  userId       String
  institution  String?
  name         String?
  mask         String?
  type         String?  // brokerage|retirement etc
  currency     String?
  lastSyncedAt DateTime?

  // Plaid mapping (optional until a user connects)
  plaidAccountId String? @unique
  plaidItemId    String?

  holdings     Holding[]
  snapshots    DailySnapshot[]

  plaidItem PlaidItem? @relation(fields: [plaidItemId], references: [plaidItemId], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CashAccount {
  id           String   @id @default(cuid())
  userId       String
  institution  String?
  name         String?
  mask         String?
  type         String?  // checking|savings
  currency     String?
  balance      Decimal  @db.Decimal(24, 8) @default(0)
  lastSyncedAt DateTime?

  // Plaid mapping (optional until a user connects)
  plaidAccountId String? @unique
  plaidItemId    String?

  plaidItem PlaidItem? @relation(fields: [plaidItemId], references: [plaidItemId], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Holding {
  id                 String   @id @default(cuid())
  brokerageAccountId String

  // Optional normalized security reference (Phase B: look-through)
  securityId String?

  // Raw display fields (keep for now; can be backfilled from Security)
  ticker     String?
  name       String
  quantity   Decimal  @db.Decimal(24, 8)
  price      Decimal? @db.Decimal(24, 8)
  value      Decimal  @db.Decimal(24, 8)

  securityType String? // etf|stock|cash|fund|bond|unknown
  assetClass   String? // us_equity|intl_equity|bonds|cash|other
  geography    String? // us|intl|global
  style        String? // growth|value|blend

  asOf DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brokerageAccount BrokerageAccount @relation(fields: [brokerageAccountId], references: [id], onDelete: Cascade)
  security         Security?        @relation(fields: [securityId], references: [id], onDelete: SetNull)

  @@index([brokerageAccountId])
  @@index([securityId])
}

model DailySnapshot {
  id                 String   @id @default(cuid())
  brokerageAccountId String

  date        DateTime // store at midnight UTC or normalized day
  totalValue  Decimal  @db.Decimal(24, 8)
  changeAbs   Decimal? @db.Decimal(24, 8)
  changePct   Decimal? @db.Decimal(10, 6)

  createdAt  DateTime @default(now())
  computedAt DateTime @default(now()) // When snapshot values were last computed

  brokerageAccount BrokerageAccount @relation(fields: [brokerageAccountId], references: [id], onDelete: Cascade)

  @@unique([brokerageAccountId, date])
}

model PlaidItem {
  id           String   @id @default(cuid())
  userId       String

  // Plaid identifiers
  plaidItemId  String   @unique
  accessToken  String

  // Optional institution info captured from Link metadata
  institutionId   String?
  institutionName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts     BrokerageAccount[]
  cashAccounts CashAccount[]

  @@index([userId])
}

// Migration: npx prisma migrate dev --name add_user_security_override
model UserSecurityOverride {
  id               String   @id @default(cuid())
  userId           String
  tickerNormalized String
  assetClass       String   // us_equity|intl_equity|bonds|cash|other
  geography        String?  // us|intl|global
  style            String?  // growth|value|blend
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tickerNormalized])
  @@index([userId])
  @@index([tickerNormalized])
}

model Security {
  id String @id @default(cuid())

  // Identifiers
  ticker String?
  name   String
  isin   String?
  cusip  String?

  // Classification
  securityType String? // etf|stock|fund|bond|crypto|cash|unknown
  assetClass   String? // us_equity|intl_equity|bonds|cash|other
  geography    String? // us|intl|global
  style        String? // growth|value|blend
  sector       String? // optional (e.g., Technology, Financials)

  // Data source metadata
  primaryExchange String?
  currency        String?
  dataProvider    String? // polygon|massive|other

  // Relationships
  holdings            Holding[]
  etfConstituents     EtfConstituent[] @relation("EtfToConstituents")
  constituentOfEtfs   EtfConstituent[] @relation("ConstituentToEtfs")
  pricesDaily         SecurityPriceDaily[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticker])
  @@index([isin])
  @@index([cusip])
}

model EtfConstituent {
  id String @id @default(cuid())

  // The ETF / fund
  etfSecurityId String
  // The underlying constituent
  constituentSecurityId String

  // Weight of constituent within the ETF (0-1 or 0-100; keep consistent in code)
  weight Decimal @db.Decimal(10, 6)

  // As-of date from the provider
  asOf DateTime

  // Optional metadata
  source       String? // polygon|massive|issuer|other
  sourceSymbol String? // if provider uses a different identifier

  etf         Security @relation("EtfToConstituents", fields: [etfSecurityId], references: [id], onDelete: Cascade)
  constituent Security @relation("ConstituentToEtfs", fields: [constituentSecurityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([etfSecurityId, constituentSecurityId, asOf])
  @@index([etfSecurityId])
  @@index([constituentSecurityId])
}

model SecurityPriceDaily {
  id String @id @default(cuid())

  securityId String
  date       DateTime // normalized day

  open  Decimal? @db.Decimal(24, 8)
  high  Decimal? @db.Decimal(24, 8)
  low   Decimal? @db.Decimal(24, 8)
  close Decimal? @db.Decimal(24, 8)

  // Optional convenience fields
  adjClose Decimal? @db.Decimal(24, 8)
  volume   BigInt?

  source String? // polygon|massive|other

  security  Security @relation(fields: [securityId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([securityId, date])
  @@index([date])
}

model FundProfile {
  id String @id @default(cuid())

  // Primary identifier
  ticker String @unique

  // Optional display fields
  name String?

  // Phase 1 bucketing (MVP)
  assetClass String // us_equity|intl_equity|bonds|cash|other
  geography  String? // us|intl|global
  style      String? // growth|value|blend
  marketCapBias String? // large|mid|small|all

  // Where this classification came from
  source String? // manual|etfdb|issuer|other
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetClass])
  @@index([geography])
}
