generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id        String   @id // Clerk userId
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Stripe subscription fields
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  subscriptionStatus   String?   // active|past_due|canceled|trialing|none
  subscriptionEndsAt   DateTime?

  // Referral system
  referralCode String? @unique // User's unique referral code for sharing

  profile           Profile?
  accounts          BrokerageAccount[]
  cashAccounts      CashAccount[]
  plaidItems        PlaidItem[]
  overrides         UserSecurityOverride[]
  syncState         SyncState?
  userDailySnapshots UserDailySnapshot[]
  aiUsageDaily      AiUsageDaily[]
  referralsMade     Referral[] @relation("ReferrerToReferrals")
  referredBy        Referral?  @relation("RefereeToReferral")
}

model Profile {
  id            String   @id @default(cuid())
  userId        String   @unique
  ageRange      String?
  riskTolerance String?  // low|medium|high
  timeHorizon   String?  // short|long
  monthlyContributionCents Int? // default monthly contribution for rebalancer (in cents)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BrokerageAccount {
  id           String   @id @default(cuid())
  userId       String
  institution  String?
  name         String?
  mask         String?
  type         String?  // brokerage|retirement etc
  currency     String?
  lastSyncedAt DateTime?

  // Plaid mapping (optional until a user connects)
  plaidAccountId String? @unique
  plaidItemId    String?

  holdings     Holding[]
  snapshots    DailySnapshot[]

  plaidItem PlaidItem? @relation(fields: [plaidItemId], references: [plaidItemId], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CashAccount {
  id           String   @id @default(cuid())
  userId       String
  institution  String?
  name         String?
  mask         String?
  type         String?  // checking|savings
  currency     String?
  balance      Decimal  @db.Decimal(24, 8) @default(0)
  lastSyncedAt DateTime?

  // Plaid mapping (optional until a user connects)
  plaidAccountId String? @unique
  plaidItemId    String?

  plaidItem PlaidItem? @relation(fields: [plaidItemId], references: [plaidItemId], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Holding {
  id                 String   @id @default(cuid())
  brokerageAccountId String

  // Optional normalized security reference (Phase B: look-through)
  securityId String?

  // Raw display fields (keep for now; can be backfilled from Security)
  ticker     String?
  name       String
  quantity   Decimal  @db.Decimal(24, 8)
  price      Decimal? @db.Decimal(24, 8)
  value      Decimal  @db.Decimal(24, 8)

  securityType String? // etf|stock|cash|fund|bond|unknown
  assetClass   String? // us_equity|intl_equity|bonds|cash|other
  geography    String? // us|intl|global
  style        String? // growth|value|blend

  asOf DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brokerageAccount BrokerageAccount @relation(fields: [brokerageAccountId], references: [id], onDelete: Cascade)
  security         Security?        @relation(fields: [securityId], references: [id], onDelete: SetNull)

  @@index([brokerageAccountId])
  @@index([securityId])
}

model DailySnapshot {
  id                 String   @id @default(cuid())
  brokerageAccountId String

  date        DateTime // store at midnight UTC or normalized day
  totalValue  Decimal  @db.Decimal(24, 8)
  changeAbs   Decimal? @db.Decimal(24, 8)
  changePct   Decimal? @db.Decimal(10, 6)

  createdAt  DateTime @default(now())
  computedAt DateTime @default(now()) // When snapshot values were last computed

  brokerageAccount BrokerageAccount @relation(fields: [brokerageAccountId], references: [id], onDelete: Cascade)

  @@unique([brokerageAccountId, date])
}

model PlaidItem {
  id           String   @id @default(cuid())
  userId       String

  // Plaid identifiers
  plaidItemId  String   @unique
  accessToken  String

  // Optional institution info captured from Link metadata
  institutionId   String?
  institutionName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts     BrokerageAccount[]
  cashAccounts CashAccount[]

  @@index([userId])
}

// Migration: npx prisma migrate dev --name add_user_security_override
model UserSecurityOverride {
  id               String   @id @default(cuid())
  userId           String
  tickerNormalized String
  assetClass       String   // us_equity|intl_equity|bonds|cash|other
  geography        String?  // us|intl|global
  style            String?  // growth|value|blend
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tickerNormalized])
  @@index([userId])
  @@index([tickerNormalized])
}

model Security {
  id String @id @default(cuid())

  // Identifiers
  ticker String?
  name   String
  isin   String?
  cusip  String?

  // Classification
  securityType String? // etf|stock|fund|bond|crypto|cash|unknown
  assetClass   String? // us_equity|intl_equity|bonds|cash|other
  geography    String? // us|intl|global
  style        String? // growth|value|blend
  sector       String? // optional (e.g., Technology, Financials)

  // Data source metadata
  primaryExchange String?
  currency        String?
  dataProvider    String? // polygon|massive|other

  // Relationships
  holdings            Holding[]
  etfConstituents     EtfConstituent[] @relation("EtfToConstituents")
  constituentOfEtfs   EtfConstituent[] @relation("ConstituentToEtfs")
  pricesDaily         SecurityPriceDaily[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticker])
  @@index([isin])
  @@index([cusip])
}

model EtfConstituent {
  id String @id @default(cuid())

  // The ETF / fund
  etfSecurityId String
  // The underlying constituent
  constituentSecurityId String

  // Weight of constituent within the ETF (0-1 or 0-100; keep consistent in code)
  weight Decimal @db.Decimal(10, 6)

  // As-of date from the provider
  asOf DateTime

  // Optional metadata
  source       String? // polygon|massive|issuer|other
  sourceSymbol String? // if provider uses a different identifier

  etf         Security @relation("EtfToConstituents", fields: [etfSecurityId], references: [id], onDelete: Cascade)
  constituent Security @relation("ConstituentToEtfs", fields: [constituentSecurityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([etfSecurityId, constituentSecurityId, asOf])
  @@index([etfSecurityId])
  @@index([constituentSecurityId])
}

model SecurityPriceDaily {
  id String @id @default(cuid())

  securityId String
  date       DateTime // normalized day

  open  Decimal? @db.Decimal(24, 8)
  high  Decimal? @db.Decimal(24, 8)
  low   Decimal? @db.Decimal(24, 8)
  close Decimal? @db.Decimal(24, 8)

  // Optional convenience fields
  adjClose Decimal? @db.Decimal(24, 8)
  volume   BigInt?

  source String? // polygon|massive|other

  security  Security @relation(fields: [securityId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([securityId, date])
  @@index([date])
}

model FundProfile {
  id String @id @default(cuid())

  // Primary identifier
  ticker String @unique

  // Optional display fields
  name String?

  // Phase 1 bucketing (MVP)
  assetClass String // us_equity|intl_equity|bonds|cash|other
  geography  String? // us|intl|global
  style      String? // growth|value|blend
  marketCapBias String? // large|mid|small|all

  // Where this classification came from
  source String? // manual|etfdb|issuer|other
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetClass])
  @@index([geography])
}

// ===== DAILY SNAPSHOT SYSTEM =====

/// User-level daily snapshot aggregating all brokerage + cash accounts.
/// Written by the cron job or manual refresh. Used for historical tracking.
model UserDailySnapshot {
  id     String @id @default(cuid())
  userId String

  // Normalized to start-of-day UTC (00:00:00.000Z)
  date DateTime

  // Total portfolio value in cents (use BigInt for precision)
  totalValueCents BigInt

  // Daily change from previous snapshot in cents (optional, null if no prior snapshot)
  dailyChangeCents BigInt?

  // Asset allocation as JSON: { "us_equity": 0.515, "intl_equity": 0.10, ... }
  allocationJson Json

  // Number of holdings at snapshot time
  holdingsCount Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One snapshot per user per day
  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

/// Tracks sync state for a user's Plaid connections.
/// Provides locking, freshness checks, and rate-limit backoff.
model SyncState {
  id     String @id @default(cuid())
  userId String @unique

  // When Plaid API was last called successfully
  lastPlaidSyncAt DateTime?

  // Lock to prevent concurrent syncs
  syncInProgress Boolean   @default(false)
  syncLockAt     DateTime? // When lock was acquired (for staleness check)

  // Rate-limit backoff: if set, don't attempt sync before this time
  nextAllowedSyncAt DateTime?

  // Last sync result
  lastSyncStatus String? // "success" | "error" | "rate_limited"
  lastSyncError  String? // Error message if failed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Tracks daily AI usage per user for rate limiting.
/// One row per user per day.
model AiUsageDaily {
  id     String @id @default(cuid())
  userId String

  // Normalized to start-of-day UTC
  date DateTime

  // Number of AI requests made this day
  requests Int @default(0)

  // Optional: total tokens consumed (for future cost tracking)
  tokens Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One usage record per user per day
  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ===== DISTRIBUTION SYSTEM =====

/// Queued content items for automated distribution.
/// AI generates content → pending → you approve → approved → cron posts → published
model ContentItem {
  id String @id @default(cuid())

  // Content metadata
  type    String  // "tweet" | "thread" | "blog_post" | "email"
  topic   String  // Topic/angle this content addresses
  title   String? // For blog posts
  content String  @db.Text // The actual content (JSON for tweets, markdown for blogs)

  // Generation metadata
  generatedBy String? // Model used (gpt-4o, etc.)
  prompt      String? @db.Text // The prompt used (for debugging/refinement)

  // Publishing workflow: pending → approved → published (or failed)
  status       String    @default("pending") // pending|approved|published|failed|rejected
  scheduledFor DateTime? // Optional: schedule for future posting
  approvedAt   DateTime? // When approved in admin dashboard
  publishedAt  DateTime? // When actually posted
  publishedId  String?   // External ID (tweet ID, etc.)

  // Performance tracking (populated after publishing)
  impressions Int?
  engagements Int?
  clicks      Int?

  // Error tracking
  error String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([scheduledFor])
  @@index([createdAt])
}

/// Content topics for AI generation rotation.
/// Tracks usage to ensure variety and prevent repetition.
model ContentTopic {
  id String @id @default(cuid())

  // Categorization
  category String // "pain_point" | "education" | "product" | "engagement"
  topic    String // The specific topic/angle
  angle    String? // Optional specific angle to take
  keywords String[] // Associated keywords for SEO/hashtags

  // Topic rotation tracking
  lastUsed DateTime?
  useCount Int       @default(0)

  // Status
  active Boolean @default(true) // Can be disabled without deleting

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([lastUsed])
  @@index([active])
}

/// Distribution channel configurations.
/// Stores credentials, rate limits, and posting state per channel.
model DistributionChannel {
  id String @id @default(cuid())

  name    String  @unique // "twitter" | "email" | "blog"
  enabled Boolean @default(false)

  // Channel-specific configuration (API keys stored in env, this is for settings)
  config Json? // e.g., { "accountHandle": "@portfolioflow", "defaultHashtags": [...] }

  // Rate limiting
  postsPerDay    Int       @default(3)
  lastPostedAt   DateTime?
  dailyPostCount Int       @default(0)
  dailyResetAt   DateTime? // When daily count was last reset

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Referral tracking for viral growth.
/// Each user can have one referral code; tracks who they referred.
model Referral {
  id String @id @default(cuid())

  // The user who shared their referral code
  referrerId String

  // The user who signed up using the code (null until they convert)
  refereeId String? @unique

  // The referral code used
  code String @unique

  // Status tracking
  status String @default("pending") // pending|converted|expired|rewarded

  // Reward tracking
  referrerReward   String?   // e.g., "1_month_free"
  refereeReward    String?   // e.g., "extended_trial"
  rewardGrantedAt  DateTime?

  // Attribution
  signupSource String? // Where the referral link was shared (twitter, email, etc.)

  createdAt   DateTime  @default(now())
  convertedAt DateTime? // When the referee became a paying user

  // Relations
  referrer User  @relation("ReferrerToReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referee  User? @relation("RefereeToReferral", fields: [refereeId], references: [id], onDelete: SetNull)

  @@index([referrerId])
  @@index([code])
  @@index([status])
}

// ===== SEO/GEO BLOGGING SYSTEM =====

/// Blog topics for SEO-optimized content generation.
/// Tracks keyword targeting, geo focus, and usage rotation.
model BlogTopic {
  id String @id @default(cuid())

  // SEO targeting
  primaryKeyword    String   // Main keyword to target
  secondaryKeywords String[] // Long-tail variations
  geoKeywords       String[] // ["US investors", "UK ISA", "Australian super"]

  // Content structure
  category String  // "pain_point" | "education" | "comparison" | "guide"
  title    String  // Suggested title template
  outline  String? @db.Text // Optional content outline

  // Rotation tracking (LRU - least recently used first)
  lastUsed DateTime?
  useCount Int       @default(0)
  active   Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  blogPosts BlogPost[]

  @@index([category])
  @@index([lastUsed])
  @@index([active])
}

/// Generated blog posts for SEO/GEO content marketing.
/// Stores MDX content and metadata before committing to repo.
model BlogPost {
  id String @id @default(cuid())

  // Content
  slug        String  @unique
  title       String
  description String  @db.Text // Meta description (150-160 chars)
  content     String  @db.Text // Full MDX content with frontmatter

  // SEO metadata
  primaryKeyword    String
  secondaryKeywords String[]
  geoTarget         String?  // "US" | "UK" | "Canada" | "Australia" | null (global)

  // Generation metadata
  topicId     String?
  generatedBy String? // Model used (gpt-4o, etc.)
  prompt      String? @db.Text

  // Publishing workflow
  status      String   @default("pending") // pending | published | failed
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  topic BlogTopic? @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([slug])
  @@index([publishedAt])
}
